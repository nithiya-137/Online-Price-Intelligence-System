# Backend Express Server Configuration
# Clone from .env.example and fill in your values

# Database Configuration
DB_NAME=price_intelligence_db
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_HOST=localhost
DB_PORT=5432

# Authentication
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Server
PORT_EXPRESS=5001
NODE_ENV=development

# Email Configuration (Optional - for password reset emails)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# eBay API Credentials (Optional - if using eBay scraper)
EBAY_CLIENT_ID=your_client_id
EBAY_CLIENT_SECRET=your_client_secret
