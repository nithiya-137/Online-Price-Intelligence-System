import React, { useState, useCallback } from 'react';
import { useDropzone } from 'react-dropzone'; // You might need to install this: npm install react-dropzone
import { Upload, X, Check, Loader } from 'lucide-react';
import { motion, AnimatePresence } from 'framer-motion';
import clsx from 'clsx';

const UploadPage = () => {
    const [file, setFile] = useState(null);
    const [preview, setPreview] = useState(null);
    const [uploading, setUploading] = useState(false);
    const [results, setResults] = useState(null);
    const [error, setError] = useState(null);

    const onDrop = useCallback((acceptedFiles) => {
        const selectedFile = acceptedFiles[0];
        if (selectedFile) {
            setFile(selectedFile);
            setPreview(URL.createObjectURL(selectedFile));
            setResults(null);
            setError(null);
        }
    }, []);

    const { getRootProps, getInputProps, isDragActive } = useDropzone({
        onDrop,
        accept: { 'image/*': [] },
        multiple: false
    });

    const handleUpload = async () => {
        if (!file) return;

        setUploading(true);
        setError(null);

        const formData = new FormData();
        formData.append('file', file);

        try {
            const response = await fetch('/api/predict', {
                method: 'POST',
                body: formData,
            });

            if (!response.ok) {
                throw new Error('Failed to analyze image. Please try again.');
            }

            const data = await response.json();
            setResults(data);
        } catch (err) {
            setError(err.message);
        } finally {
            setUploading(false);
        }
    };

    const clearFile = () => {
        setFile(null);
        setPreview(null);
        setResults(null);
        setError(null);
    };

    return (
        <div className="max-w-4xl mx-auto px-6 py-12">
            <h1 className="text-3xl font-bold text-center mb-8 text-gray-800 dark:text-white">
                Analyze Product Image
            </h1>

            <div className="grid md:grid-cols-2 gap-8 items-start">
                {/* Upload Section */}
                <div className="space-y-6">
                    <div
                        {...getRootProps()}
                        className={clsx(
                            "border-2 border-dashed rounded-2xl h-80 flex flex-col items-center justify-center cursor-pointer transition-colors duration-300",
                            isDragActive ? "border-primary bg-blue-50 dark:bg-gray-800" : "border-gray-300 dark:border-gray-600 hover:border-primary",
                            preview ? "bg-gray-50 dark:bg-gray-800" : ""
                        )}
                    >
                        <input {...getInputProps()} />
                        {preview ? (
                            <div className="relative w-full h-full p-4">
                                <img src={preview} alt="Preview" className="w-full h-full object-contain rounded-lg" />
                                <button
                                    onClick={(e) => { e.stopPropagation(); clearFile(); }}
                                    className="absolute top-2 right-2 p-1 bg-white dark:bg-gray-700 rounded-full shadow-md hover:bg-red-50 text-red-500"
                                >
                                    <X className="w-5 h-5" />
                                </button>
                            </div>
                        ) : (
                            <div className="text-center p-6">
                                <Upload className="w-16 h-16 text-gray-400 mx-auto mb-4" />
                                <p className="text-lg font-medium text-gray-600 dark:text-gray-300">
                                    {isDragActive ? "Drop the image here..." : "Drag & Drop or Click to Upload"}
                                </p>
                                <p className="text-sm text-gray-400 mt-2">Supports JPG, PNG, WebP</p>
                            </div>
                        )}
                    </div>

                    <button
                        onClick={handleUpload}
                        disabled={!file || uploading}
                        className={clsx(
                            "w-full py-4 rounded-xl font-bold text-white shadow-lg transition-all flex items-center justify-center gap-2",
                            !file ? "bg-gray-300 cursor-not-allowed" :
                                uploading ? "bg-gray-500 cursor-wait" : "bg-primary hover:bg-blue-600 hover:shadow-xl"
                        )}
                    >
                        {uploading ? (
                            <>
                                <Loader className="w-5 h-5 animate-spin" /> Analyzing...
                            </>
                        ) : (
                            <>
                                Identify Product
                            </>
                        )}
                    </button>

                    {error && (
                        <div className="p-4 bg-red-100 text-red-700 rounded-lg text-sm">
                            {error}
                        </div>
                    )}
                </div>

                {/* Results Section */}
                <div className="bg-white dark:bg-gray-800 p-8 rounded-2xl shadow-lg border border-gray-100 dark:border-gray-700 min-h-[320px]">
                    <h2 className="text-xl font-bold mb-6 text-gray-800 dark:text-white border-b pb-2 dark:border-gray-700">
                        Analysis Results
                    </h2>

                    <AnimatePresence mode="wait">
                        {!results ? (
                            <motion.div
                                initial={{ opacity: 0 }}
                                animate={{ opacity: 1 }}
                                exit={{ opacity: 0 }}
                                className="flex flex-col items-center justify-center h-48 text-gray-400"
                            >
                                <Search className="w-12 h-12 mb-3 opacity-20" />
                                <p>Upload an image to see results here</p>
                            </motion.div>
                        ) : (
                            <motion.div
                                initial={{ opacity: 0, y: 10 }}
                                animate={{ opacity: 1, y: 0 }}
                                className="space-y-6"
                            >
                                <div>
                                    <h3 className="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-3">Top Prediction</h3>
                                    <div className="flex items-center justify-between p-4 bg-green-50 dark:bg-green-900/20 rounded-xl border border-green-100 dark:border-green-800">
                                        <span className="text-lg font-bold text-green-800 dark:text-green-300 capitalize">
                                            {results.predictions[0].label.replace(/_/g, ' ')}
                                        </span>
                                        <span className="px-3 py-1 bg-white dark:bg-gray-800 rounded-lg text-sm font-bold shadow-sm text-green-600">
                                            {(results.predictions[0].confidence * 100).toFixed(1)}%
                                        </span>
                                    </div>
                                </div>

                                <div>
                                    <h3 className="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-3">Other Possibilities</h3>
                                    <div className="space-y-3">
                                        {results.predictions.slice(1).map((pred, idx) => (
                                            <div key={idx} className="flex items-center justify-between p-3 bg-gray-50 dark:bg-gray-700/50 rounded-lg">
                                                <span className="text-gray-700 dark:text-gray-300 capitalize">
                                                    {pred.label.replace(/_/g, ' ')}
                                                </span>
                                                <span className="text-sm text-gray-500">
                                                    {(pred.confidence * 100).toFixed(1)}%
                                                </span>
                                            </div>
                                        ))}
                                    </div>
                                </div>

                                <div className="mt-8 pt-6 border-t dark:border-gray-700">
                                    <button className="w-full py-3 bg-secondary hover:bg-emerald-600 text-white font-semibold rounded-lg shadow-md transition-colors flex items-center justify-center gap-2">
                                        <ShoppingBag className="w-4 h-4" />
                                        Find Deals for this Item
                                    </button>
                                    <p className="text-xs text-center text-gray-400 mt-2">
                                        *Price comparison feature coming soon
                                    </p>
                                </div>
                            </motion.div>
                        )}
                    </AnimatePresence>
                </div>
            </div>
        </div>
    );
};

export default UploadPage;
