# Frontend Configuration (Vite)
# Clone from .env.example and fill in your values

# API Configuration
# During development, the Vite proxy (vite.config.js) will forward requests
# to the backend servers. You can optionally set custom API URLs here:
# VITE_API_URL=http://localhost:5001

# For production, you may want to use a different API endpoint
# VITE_API_PROD_URL=https://api.yoursite.com

# Feature Flags
VITE_ENABLE_RECOMMENDATIONS=true
VITE_ENABLE_PRICE_TRENDS=true
